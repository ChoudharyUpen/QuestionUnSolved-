class Result {

    public static int nonDivisibleSubset(int k, List<Integer> s) {

        int[] rem = new int[k];

        // Count frequency of each remainder
        for (int num : s) {
            rem[num % k]++;
        }

        int result = 0;

        // Only one element with remainder 0
        if (rem[0] > 0) {
            result++;
        }

        // Compare remainder pairs
        for (int i = 1; i <= k / 2; i++) {

            // Special case when k is even
            if (i == k - i) {
                if (rem[i] > 0)
                    result++;
            } else {
                result += Math.max(rem[i], rem[k - i]);
            }
        }

        return result;
    }
}




