class Result {

    public static List<Integer> cutTheSticks(List<Integer> arr) {

        Collections.sort(arr);
        List<Integer> result = new ArrayList<>();

        int n = arr.size();
        result.add(n);

        for (int i = 1; i < n; i++) {
            if (!arr.get(i).equals(arr.get(i - 1))) {
                result.add(n - i);
            }
        }

        return result;
    }

  }




